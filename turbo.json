{
  "$schema": "https://turborepo.org/schema.json",
  "baseBranch": "origin/main",

  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist/index.d.ts"]
    },
    "test": {
      "outputs": [],
      "inputs": ["src/**/*.test.tsx", "src/**/*.test.ts"]
    }
  }
}
