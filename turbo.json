{
  "$schema": "https://turborepo.org/schema.json",
  "baseBranch": "origin/main",
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "outputs": [],
      "inputs": ["src/**/*.test.tsx", "src/**/*.test.ts"]
    },
    "release": {
      "dependsOn": ["^release"],
      "outputs": ["CHANGELOG.md", "package.json"],
      "inputs": []
    }
  }
}
