{
  "$schema": "https://turborepo.org/schema.json",
  "baseBranch": "origin/main",
  "pipeline": {
    "build": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": [],
      "inputs": ["src/**/*.tsx", "src/**/*.ts"]
    },
    "release": {
      "dependsOn": ["build", "test"],
      "outputs": []
    },
    "local-release": {
      "cache": false,
      "dependsOn": ["build", "test"],
      "outputs": []
    },
    "deploy": {
      "dependsOn": ["release"],
      "outputs": []
    },
    "local-deploy": {
      "cache": false,
      "dependsOn": ["local-release"],
      "outputs": []
    },
    "@srclaunch/cli#build": {
      "dependsOn": ["@srclaunch/types#build"],
      "outputs": []
    },
    "@srclaunch/types#release": {
      "dependsOn": ["@srclaunch/cli#build"],
      "outputs": []
    },
    "@srclaunch/types#local-release": {
      "dependsOn": ["@srclaunch/cli#build"],
      "outputs": []
    }
  }
}
