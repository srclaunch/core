{
  "name": "@srclaunch/logger",
  "description": "Logging utilties",
  "author": "Steven Bennett <steven@srclaunch.com>",
  "license": "MIT",
  "version": "0.1.91",
  "engines": {
    "node": ">=16",
    "yarn": ">=3.2.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "package.json",
    "dist"
  ],
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.umd.cjs"
    }
  },
  "scripts": {
    "yui": "yarn upgrade-interactive",
    "qr": "yarn srclaunch changesets add --files \".\" --message \"Quick release\" --type \"chore\" && yarn srclaunch release --push",
    "build": "yarn srclaunch build",
    "test": "yarn srclaunch test",
    "test:watch": "yarn srclaunch test --watch",
    "test:coverage": "yarn srclaunch test --coverage",
    "release": "yarn srclaunch release"
  },
  "dependencies": {
    "luxon": "2.4.0",
    "nanoid": "3.3.4",
    "picocolors": "1.0.0"
  },
  "devDependencies": {
    "@srclaunch/cli": "workspace:packages/cli",
    "@srclaunch/types": "workspace:^",
    "@types/express": "^4.17.13",
    "@types/node": "^17.0.35"
  }
}
