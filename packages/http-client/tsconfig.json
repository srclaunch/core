{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "paths": {
      "@srclaunch/cli": [
        "../cli"
      ],
      "@srclaunch/exceptions": ["../exceptions"],

      "@srclaunch/logger": ["../logger"],

      "@srclaunch/types": [
        "../types"
      ],

    },
    "rootDir": "./src",
  },
  "references": [

    {
      "path": "../cli"
    },
    {
      "path": "../exceptions"
    },

    {
      "path": "../logger"
    },

      {
      "path": "../types"
    }
  ],
  "include": [
    "src/**/*.ts"
  ]
}
