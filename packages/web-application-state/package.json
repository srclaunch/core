{
  "name": "@srclaunch/web-application-state",
  "description": "Redux state and utilities used by AppLab web applications",
  "author": "Steven Bennett <steven@srclaunch.com>",
  "license": "MIT",
  "version": "0.1.78",
  "engines": {
    "node": ">=16",
    "yarn": ">=3.2.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "package.json",
    "dist"
  ],
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.umd.cjs"
    }
  },
  "scripts": {
    "yui": "yarn upgrade-interactive",
    "qr": "yarn srclaunch changesets add --files \".\" --message \"Quick release\" --type \"chore\" && yarn srclaunch release --push",
    "build": "yarn srclaunch build",
    "test": "yarn srclaunch test",
    "test:watch": "yarn srclaunch test --watch",
    "test:coverage": "yarn srclaunch test --coverage",
    "release": "yarn srclaunch release"
  },
  "dependencies": {
    "@reduxjs/toolkit": "1.8.1",
    "@srclaunch/exceptions": "workspace:packages/exceptions",
    "@srclaunch/http-client": "workspace:packages/http-client",
    "@srclaunch/i18n": "workspace:packages/i18n",
    "@srclaunch/logger": "workspace:packages/logger",
    "@srclaunch/themes": "workspace:packages/themes",
    "@srclaunch/web-environment": "workspace:packages/web-environment",
    "amazon-cognito-identity-js": "5.2.8",
    "crypto-js": "4.1.1",
    "history": "5.3.0",
    "luxon": "2.4.0",
    "nanoid": "3.3.4",
    "react-redux": "8.0.1",
    "react-router": "6.3.0",
    "react-router-dom": "6.3.0",
    "redux": "4.2.0"
  },
  "devDependencies": {
    "@srclaunch/cli": "workspace:packages/cli",
    "@srclaunch/types": "workspace:packages/types",
    "@testing-library/jest-dom": "5.16.4",
    "@testing-library/react": "13.2.0",
    "@testing-library/user-event": "14.1.1",
    "@types/jest": "27.5.0"
  },
  "peerDependencies": {
    "react": "18.1.0",
    "react-dom": "18.1.0",
    "styled-components": "5.3.5"
  }
}
