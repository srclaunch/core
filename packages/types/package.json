{
  "name": "@srclaunch/types",
  "description": "TypeScript definitions used by SrcLaunch projects and workspaces.",
  "author": "Steven Bennett <steven@srclaunch.com>",
  "license": "MIT",
  "version": "0.1.292",
  "engines": {
    "node": ">=14"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "package.json",
    "dist"
  ],
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./action": {
      "import": "./dist/action"
    }
  },
  "scripts": {
    "yui": "yarn upgrade-interactive",
    "qr": "yarn srclaunch changesets add --files \".\" --message \"Quick release\" --type \"chore\" && yarn srclaunch release --push",
    "build": "yarn srclaunch build",
    "release": "yarn srclaunch release"
  },
  "devDependencies": {
    "@srclaunch/cli": "workspace:packages/cli"
  }
}
