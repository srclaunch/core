{
  "name": "@srclaunch/types",
  "description": "TypeScript definitions used by SrcLaunch projects and workspaces.",
  "author": "Steven Bennett <steven@srclaunch.com>",
  "license": "MIT",
  "version": "0.2.0",
  "engines": {
    "node": ">=16"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build:esbuild": "esbuild --bundle --minify --outfile=dist/index.js --format=esm --target=esnext --platform=neutral src/index.ts",
    "build:spack": "spack --config \"$PWD/spack.config.cjs\"",
    "build:types": "tsc ",
    "build": "rm -fr ./dist && pnpm build:esbuild && pnpm build:types"
  },
  "devDependencies": {
    "@srclaunch/dx": "workspace:*",
    "@types/react": "^18.0.9"
  }
}
