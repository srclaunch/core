{
  "name": "@srclaunch/logic",
  "description": "Actions, parsers, generators, transformers and other programming abstractions",
  "author": "Steven Bennett <steven@srclaunch.com>",
  "license": "MIT",
  "version": "0.2.0",
  "engines": {
    "node": ">=16"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "package.json",
    "dist"
  ],
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.umd.js"
    }
  },
  "scripts": {
    "qr": "srclaunch changesets add --files \".\" --message \"Quick release\" --type \"chore\" && srclaunch release --push",
    "nobuild": "srclaunch build",
    "test": "srclaunch test",
    "test:watch": "srclaunch test --watch",
    "test:coverage": "srclaunch test --coverage",
    "release": "srclaunch release"
  },
  "dependencies": {
    "email-validator": "^2.0.4",
    "fs-extra": "^10.1.0",
    "js-file-download": "^0.4.12",
    "js-yaml": "^4.1.0",
    "password-validator": "^5.3.0",
    "unconfig": "^0.3.4"
  },
  "devDependencies": {
    "@types/fs-extra": "^9.0.13",
    "@types/js-yaml": "^4.0.5",
    "@types/node": "^17.0.35"
  }
}
