{
  "name": "@srclaunch/data-client",
  "description": "Wrapper around Sequelize for basic CRUD operations",
  "author": "Steven Bennett <steven@srclaunch.com>",
  "license": "MIT",
  "version": "0.1.38",
  "engines": {
    "node": ">=16"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "package.json",
    "dist"
  ],
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "scripts": {
    "build": "yarn clean && yarn build:applab",
    "build:applab": "applab build",
    "clean": "rm -fr ./dist",
    "git:push": "git push --follow-tags origin main",
    "qr": "yarn build && git add . && git commit -m \"Quick release - patch\" && yarn release",
    "release": "yarn version:patch && yarn git:push",
    "test": "ava",
    "version:patch": "standard-version",
    "yui": "yarn upgrade-interactive"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.17.10",
    "@babel/preset-typescript": "^7.16.7",
    "@srclaunch/cli": "workspace:packages/cli",
    "@srclaunch/types": "workspace:packages/types",
    "@types/jest": "^27.4.1",
    "@types/node": "^17.0.30",
    "@types/pg": "^8.6.5",
    "@types/pluralize": "^0.0.29",
    "@types/tunnel-ssh": "^4.1.1"
  },
  "dependencies": {
    "@srclaunch/exceptions": "workspace:packages/exceptions",
    "@srclaunch/logger": "workspace:packages/logger",
    "@srclaunch/node-environment": "workspace:packages/node-environment",
    "change-case": "^4.1.2",
    "pg": "^8.7.3",
    "pg-hstore": "^2.3.4",
    "pluralize": "^8.0.0",
    "sequelize": "6.19.0",
    "tunnel-ssh": "^4.1.6"
  }
}
