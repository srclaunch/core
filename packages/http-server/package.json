{
  "name": "@srclaunch/http-server",
  "description": "Simple API wrapper around Express server",
  "author": "Steven Bennett <steven@srclaunch.com>",
  "license": "MIT",
  "version": "0.1.75",
  "engines": {
    "node": ">=16"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "package.json",
    "dist"
  ],
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "scripts": {
    "build": "yarn clean && yarn build:applab",
    "build:applab": "applab build",
    "clean": "rm -fr ./dist",
    "git:push": "git push --follow-tags origin main",
    "qr": "yarn build && git add . && git commit -m \"Quick release - patch\" && yarn release",
    "release": "yarn test:coverage && yarn version:patch && yarn git:push",
    "test": "yarn ava",
    "test:coverage": "yarn c8 ava",
    "test:watch": "yarn ava --watch",
    "version:patch": "standard-version",
    "yui": "yarn upgrade-interactive"
  },
  "devDependencies": {
    "@srclaunch/cli": "workspace:packages/cli",
    "@srclaunch/http-client": "workspace:packages/http-client",
    "@srclaunch/types": "workspace:packages/types",
    "@types/async-exit-hook": "^2.0.0",
    "@types/compression": "^1.7.2",
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.13",
    "@types/express-serve-static-core": "^4.17.28",
    "@types/jsonwebtoken": "^8.5.8",
    "@types/keygrip": "^1.0.2",
    "@types/multer": "^1.4.7",
    "@types/node": "^17.0.23"
  },
  "dependencies": {
    "@srclaunch/exceptions": "workspace:packages/exceptions",
    "@srclaunch/logger": "workspace:packages/logger",
    "@srclaunch/node-environment": "workspace:packages/node-environment",
    "async-exit-hook": "^2.0.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.17.3",
    "multer": "^1.4.4"
  }
}
