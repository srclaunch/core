{
  "name": "@srclaunch/cli",
  "description": "Command line tools used by SrcLaunch applications and services",
  "author": "Steven Bennett <steven@srclaunch.com>",
  "license": "MIT",
  "version": "0.3.10",
  "engines": {
    "node": ">=16"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "srclaunch": "dist/index.js"
  },
  "type": "module",
  "files": [
    "package.json",
    "dist"
  ],
  "module": "./dist/index.js",
  "scripts": {
    "build:es": "esbuild --external:'@rauschma/stringio' --external:'@yarnpkg/core' --external:mocha --external:'vite-plugin-pwa' --external:c8 --external:diff --external:'fs-extra' --external:globby --external:'unconfig' --external:'@srclaunch/logic' --external:semver --external:esbuild --external:jest --external:'latest-version' --external:meow --external:picocolors --external:prompts --external:react --external:'semantic-release' --external:'semantic-release-monorepo' --external:'simple-git' --external:'standard-version' --external:tape --external:typescript --external:vite --external:'@vitejs/plugin-react' --external:'update-notifier' --external:vitest --bundle --minify --outfile=dist/index.js --format=esm --target=esnext --define:'navigator={}' --platform=node src/index.ts",
    "build:self": "node ./dist/index.js build",
    "build:cli": "rm -fr ./dist && pnpm build:es && tsc --build",
    "dev": "NODE_ENV=dev && node --loader ts-node/esm --experimental-specifier-resolution=node ./src/index.ts",
    "git:push": "git push --follow-tags origin main",
    "qr": "pnpm build && git add . && git commit -m \"Quick release\" && pnpm release",
    "release": "srclaunch release",
    "start": "node --experimental-modules --experimental-specifier-resolution=node dist/index.js",
    "test": "ava ./src/__tests__/**",
    "test:cov": "c8 --all --clean --include src --exclude 'src/__tests__/**' ava ./src/__tests__/** && c8 report --all --reporter json-summary --reporter lcov --include src --exclude 'src/__tests__/**'",
    "test:watch": "ava --watch"
  },
  "devDependencies": {
    "@srclaunch/dx": "workspace:*",
    "@srclaunch/types": "workspace:*",
    "@types/diff": "^5.0.2",
    "@types/fs-extra": "^9.0.13",
    "@types/luxon": "^2.3.2",
    "@types/mocha": "^9.1.1",
    "@types/node": "^17.0.42",
    "@types/node-emoji": "^1.8.1",
    "@types/pluralize": "^0.0.29",
    "@types/prompts": "^2.0.14",
    "@types/react": "^18.0.9",
    "@types/rimraf": "^3.0.2",
    "@types/semantic-release": "^17.2.3",
    "@types/semver": "^7.3.9",
    "@types/standard-version": "^7.0.1",
    "@types/tape": "^4.13.2",
    "@types/update-notifier": "^5.1.0"
  },
  "dependencies": {
    "@rauschma/stringio": "^1.4.0",
    "@types/async": "^3.2.13",
    "@vitejs/plugin-react": "^1.3.2",
    "@yarnpkg/core": "^3.2.1",
    "ansi-styles": "^6.1.0",
    "async": "^3.2.3",
    "babel-plugin-styled-components": "^2.0.7",
    "c8": "^7.11.2",
    "change-case": "^4.1.2",
    "css-tree": "^2.1.0",
    "diff": "^5.1.0",
    "dir-glob": "^3.0.1",
    "esbuild": "^0.14.43",
    "fs-extra": "^10.1.0",
    "globby": "^13.1.2",
    "jest": "^28.1.0",
    "latest-version": "^6.0.0",
    "luxon": "^2.4.0",
    "meow": "^10.1.2",
    "mocha": "^10.0.0",
    "nanoid": "^3.3.4",
    "picocolors": "^1.0.0",
    "pluralize": "^8.0.0",
    "prompts": "^2.4.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-is": "^18.2.0",
    "semantic-release": "^19.0.3",
    "semantic-release-commit-filter": "^1.0.2",
    "semantic-release-monorepo": "^7.0.5",
    "semver": "^7.3.7",
    "shelljs": "^0.8.5",
    "simple-git": "^3.7.1",
    "standard-version": "^9.3.2",
    "styled-components": "^5.3.5",
    "tape": "^5.5.3",
    "terminal-link": "^3.0.0",
    "ts-jest": "^28.0.2",
    "ts-node": "^10.7.0",
    "typescript": "4.6.4",
    "unconfig": "^0.3.4",
    "update-notifier": "^5.1.0",
    "vite": "^2.9.9",
    "vite-plugin-pwa": "^0.12.0",
    "vitest": "^0.14.2"
  }
}
