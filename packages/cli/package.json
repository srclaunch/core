{
  "name": "@srclaunch/cli",
  "description": "Command line tools used by SrcLaunch applications and services",
  "author": "Steven Bennett <steven@srclaunch.com>",
  "license": "MIT",
  "version": "0.1.631",
  "engines": {
    "node": ">=16"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "srclaunch": "dist/index.mjs"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "package.json",
    "dist"
  ],
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build:cjs": "yarn esbuild --external:'@yarnpkg/core' --external:c8 --external:diff --external:'@srclaunch/logic' --external:semver --external:esbuild --external:ink  --external:'latest-version' --external:meow --external:ora --external:picocolors --external:prompts --external:react --external:'simple-git' --external:'standard-version' --external:typescript --external:vite --external:'@vitejs/plugin-react' --external:'update-notifier' --sourcemap --bundle --minify --outfile=dist/index.cjs --format=cjs --target=esnext --define:'navigator={}' --platform=node src/index.ts",
    "build:es": "yarn esbuild --external:'@yarnpkg/core' --external:c8 --external:diff --external:'@srclaunch/logic' --external:semver --external:esbuild --external:ink --external:'latest-version' --external:meow --external:ora --external:picocolors --external:prompts --external:react --external:'simple-git' --external:'standard-version' --external:typescript --external:vite --external:'@vitejs/plugin-react' --external:'update-notifier' --sourcemap --bundle --minify  --outfile=dist/index.mjs --format=esm --target=esnext --define:'navigator={}' --platform=node src/index.ts",
    "build:self": "node ./dist/index.js build",
    "build": "yarn clean && yarn build:cjs && yarn build:es",
    "clean": "rm -fr dist",
    "dev": "NODE_ENV=dev && node --loader ts-node/esm --experimental-specifier-resolution=node ./src/index.ts",
    "git:push": "git push --follow-tags origin main",
    "qr": "yarn build && git add . && git commit -m \"Quick release\" && yarn release",
    "release": "yarn version:patch && yarn git:push",
    "start": "node --experimental-modules --experimental-specifier-resolution=node dist/index.js",
    "test": "yarn ava ./src/__tests__/**",
    "test:coverage": "yarn c8 --all --clean --include src --exclude 'src/__tests__/**' ava ./src/__tests__/** && yarn c8 report --all --reporter json-summary --reporter lcov --include src --exclude 'src/__tests__/**'",
    "test:watch": "yarn ava --watch",
    "version:patch": "standard-version",
    "yui": "yarn upgrade-interactive"
  },
  "devDependencies": {
    "@srclaunch/types": "workspace:packages/types",
    "@types/diff": "^5.0.2",
    "@types/luxon": "^2.3.2",
    "@types/node": "^17.0.33",
    "@types/node-emoji": "^1.8.1",
    "@types/pluralize": "^0.0.29",
    "@types/prompts": "^2.0.14",
    "@types/react": "^18.0.9",
    "@types/rimraf": "^3.0.2",
    "@types/semver": "^7.3.9",
    "@types/standard-version": "^7.0.1",
    "@types/update-notifier": "^5.1.0"
  },
  "dependencies": {
    "@srclaunch/dx": "workspace:packages/dx",
    "@srclaunch/exceptions": "workspace:packages/exceptions",
    "@srclaunch/logic": "workspace:packages/logic",
    "@srclaunch/node-environment": "workspace:packages/node-environment",
    "@types/async": "^3.2.13",
    "@vitejs/plugin-react": "^1.3.2",
    "@yarnpkg/core": "^3.2.1",
    "async": "^3.2.3",
    "ava": "^4.2.0",
    "c8": "^7.11.2",
    "change-case": "^4.1.2",
    "css-tree": "^2.1.0",
    "diff": "^5.1.0",
    "dir-glob": "^3.0.1",
    "esbuild": "^0.14.39",
    "ink": "^3.2.0",
    "ink-multi-select": "^2.0.0",
    "ink-spinner": "^4.0.3",
    "jest": "^28.1.0",
    "jest-cli": "^28.1.0",
    "latest-version": "^6.0.0",
    "luxon": "^2.4.0",
    "meow": "^10.1.2",
    "nanoid": "^3.3.4",
    "ora": "^6.1.0",
    "picocolors": "^1.0.0",
    "pluralize": "^8.0.0",
    "prompts": "^2.4.2",
    "react": "^18.1.0",
    "semver": "^7.3.7",
    "shelljs": "^0.8.5",
    "simple-git": "^3.7.1",
    "standard-version": "^9.3.2",
    "terminal-link": "^3.0.0",
    "ts-jest": "^28.0.2",
    "ts-node": "^10.7.0",
    "typescript": "4.6.4",
    "update-notifier": "^5.1.0",
    "vite": "^2.9.9"
  },
  "packageManager": "yarn@3.2.1"
}
